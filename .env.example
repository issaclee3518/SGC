EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-publishable-key

# Google 로그인 (Supabase Dashboard)
# 1. Authentication → Providers → Google 활성화
# 2. Authentication → URL Configuration → Redirect URLs:
#    scrollgame://google-auth
# 3. app.json scheme: scrollgame (이미 설정됨)

# SGS 주소 (비우면 Expo Metro IP + :5001 자동). macOS 5000 = AirPlay
# EXPO_PUBLIC_API_URL=http://127.0.0.1:5001
